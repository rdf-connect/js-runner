@prefix rdfc: <https://w3id.org/rdf-connect#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

<> owl:imports <http://localhost:3000/>,
  <http://localhost:3000/processors/send.ttl>,
  <http://localhost:3000/processors/echo.ttl>,
  <http://localhost:3000/processors/log.ttl>,
  <http://localhost:3000/node_modules/@rdfc/http-utils-processor-ts/server.ttl>.

#
<> a rdfc:Pipeline;
  rdfc:consistsOf [
    rdfc:instantiates <http://localhost:3000/jsRunner>;
    rdfc:processor <server>, <echo>, <log>;
  ].

<server> a rdfc:HttpServer;
  rdfc:port 3001;
  rdfc:writer <1>.

<1> a rdfc:Writer, rdfc:Reader.
<2> a rdfc:Writer, rdfc:Reader.
<sender> a rdfc:SendProcessor;
  rdfc:writer <1>;
  rdfc:msg "hallo", "world".

<echo> a rdfc:EchoProcessor;
  rdfc:reader <1>;
  rdfc:writer <2>.

<log> a rdfc:LogProcessor;
  rdfc:reader <2>.

