@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdfc: <https://w3id.org/rdf-connect#>.

<> owl:imports <./node_modules/@rdfc/js-runner/index.ttl>,
  <./processors/echo.ttl>,
  <./processors/log.ttl>,
  <./processors/send.ttl>.

<> a rdfc:Pipeline;
  rdfc:consistsOf [
    rdfc:instantiates rdfc:NodeRunner;
    rdfc:processor <sender>, <echo>, <log>;
  ].

<1> a rdfc:Writer, rdfc:Reader.
<2> a rdfc:Writer, rdfc:Reader.
<sender> a rdfc:SendProcessor;
  rdfc:writer <1>;
  rdfc:msg "hallo", "world".

<echo> a rdfc:EchoProcessor;
  rdfc:reader <1>;
  rdfc:writer <2>.

<log> a rdfc:LogProcessor;
  rdfc:reader <2>.

